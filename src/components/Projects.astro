---
const projects = [
  {
    emoji: '🚀',
    title: 'Proyecto Destacado',
    description:
      'Descripción del proyecto. Explica qué hace, qué tecnologías usaste y qué problema resuelve de forma concisa y directa.',
    image: 'https://placehold.co/640x360/111113/818cf8?text=Proyecto+1',
    tags: ['Astro', 'Tailwind', 'TypeScript'],
    github: 'https://github.com',
    demo: 'https://example.com',
  },
  {
    emoji: '🌐',
    title: 'Aplicación Web',
    description:
      'Otra descripción de proyecto interesante. Menciona los retos técnicos y cómo los superaste durante el desarrollo.',
    image: 'https://placehold.co/640x360/111113/f472b6?text=Proyecto+2',
    tags: ['React', 'Node.js', 'MongoDB'],
    github: 'https://github.com',
    demo: 'https://example.com',
  },
  {
    emoji: '🎮',
    title: 'Juego Interactivo',
    description:
      'Un proyecto de juego o algo interactivo. Destaca las mecánicas implementadas y la tecnología utilizada.',
    image: 'https://placehold.co/640x360/111113/818cf8?text=Proyecto+3',
    tags: ['Unity', 'C#', 'Blender'],
    github: 'https://github.com',
  },
];
---

<section id="proyectos" class="py-28">
  <div class="max-w-5xl mx-auto px-6">
    <!-- Section label -->
    <div class="animate-on-scroll">
      <p class="section-label">02 — Proyectos</p>
      <h2 class="text-4xl font-bold tracking-tight mb-14">
        Mis proyectos <span class="gradient-text">favoritos</span>
      </h2>
    </div>

    <div class="space-y-5">
      {projects.map((project) => (
        <article class="animate-on-scroll group rounded-2xl border border-white/6 bg-dark-lighter overflow-hidden card-hover">
          <!-- Image -->
          <div class="relative overflow-hidden">
            <img
              src={project.image}
              alt={project.title}
              class="w-full h-44 object-cover opacity-80 group-hover:opacity-100 group-hover:scale-[1.03] transition-all duration-500"
              loading="lazy"
            />
            <div
              class="absolute inset-0"
              style="background: linear-gradient(to top, #111113 0%, transparent 55%);"
              aria-hidden="true"
            ></div>
          </div>

          <!-- Content -->
          <div class="px-6 pb-6 -mt-4 relative">
            <div class="flex items-start justify-between gap-4 mb-2">
              <h3 class="text-lg font-semibold">
                {project.emoji}&nbsp;{project.title}
              </h3>
              <div class="flex items-center gap-3 shrink-0 pt-0.5">
                {project.github && (
                  <a
                    href={project.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-gray-custom hover:text-white transition-colors"
                    aria-label={`Código de ${project.title}`}
                  >
                    <svg class="w-4.5 h-4.5" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                    </svg>
                  </a>
                )}
                {project.demo && (
                  <a
                    href={project.demo}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-gray-custom hover:text-white transition-colors"
                    aria-label={`Demo de ${project.title}`}
                  >
                    <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
                    </svg>
                  </a>
                )}
              </div>
            </div>

            <p class="text-base text-white/60 leading-relaxed mb-4">{project.description}</p>

            <div class="flex flex-wrap gap-1.5">
              {project.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
