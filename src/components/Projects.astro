---
import Icon from '@components/Icon.astro';
import SectionHeading from '@components/SectionHeading.astro';
import SkillBadge from '@components/SkillBadge.astro';
import { projects } from '@data/site';
import { getLangFromUrl, useTranslations } from '@i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="projects" class="mx-auto max-w-screen-2xl px-4 xs:px-6 sm:px-8" data-observed-section="2">
  <SectionHeading title={t('projects.heading')} />

  <ul class="space-y-12 py-12 sm:mx-4 lg:space-y-24">
    {
      projects.map((project) => (
        <li>
          <article
            data-project={project.name}
            data-year={project.year}
            class="relative flex flex-col-reverse bg-background items-center xl:grid xl:grid-cols-12 xl:grid-rows-1"
          >
            <div class="flex flex-col rounded-xl border px-7 py-6 md:px-10 md:py-8 xl:col-start-1 xl:col-end-11 xl:row-start-1 xl:min-h-96 *:xl:max-w-xl *:2xl:max-w-2xl">
              <header class="mt-2 py-2 xl:mt-0">
                <div class="inline-flex w-full xs:w-auto xs:flex-row">
                  <h3 class="inline text-balance font-header text-3xl font-semibold text-primary xs:whitespace-nowrap xs:text-left">
                    {project.name}
                  </h3>
                  <div class="ml-2 inline-flex gap-1 xs:mt-0">
                    {project.links.map((link) => (
                      <a
                        target="_blank"
                        rel="noopener noreferrer"
                        data-tippy-content={t(link.tippy)}
                        href={link.href}
                        aria-label={`${t('a11y.linkTo')} "${t(link.tippy)}" ${t('a11y.forProject')} "${project.name}" ${t('a11y.opensInNewTab')}`}
                        class="group aspect-square content-center rounded-md p-2 text-2xl font-semibold text-foreground/80 transition-colors hover:bg-accent hover:text-accent-foreground"
                      >
                        <Icon name={link.icon} class="size-5 xs:size-6" />
                      </a>
                    ))}
                  </div>
                </div>
                <p class="mt-2 text-balance text-base text-foreground xs:text-pretty xs:text-left md:text-lg">{t(project.blurb)}</p>
              </header>

              <div class="mt-8 flex grow flex-col justify-between space-y-6">
                {project.paragraphs.map((p) => (
                  <p data-project-description class="text-pretty pr-0 text-base text-foreground/70 md:text-lg xl:pr-16" set:html={t(p)} />
                ))}
                <ul class="flex flex-wrap gap-4">
                  {project.skills.map((skill) => (
                    <li>
                      <SkillBadge label={skill.label} icon={skill.icon} shine />
                    </li>
                  ))}
                </ul>
              </div>
            </div>

            <div
              class="relative -mb-4 max-w-[90%] rounded-xl md:max-w-[80%] xl:col-start-7 xl:-col-end-1 xl:row-start-1 xl:my-2.5 xl:ml-5 xl:max-w-none xl:content-center"
              data-project-preview
            >
              <picture>
                {project.media.sources.map((s) => (
                  <source srcset={s.srcset} type={s.type} />
                ))}
                <img
                  src={project.media.cover}
                  data-project-image
                  class="pointer-events-none relative rounded-xl"
                  alt={t(project.media.alt)}
                  width="910"
                  height="512"
                  loading="lazy"
                  decoding="async"
                />
              </picture>

              <div data-project-video class="absolute inset-x-0 bottom-0 mx-auto size-[80%]">
                <video
                  muted
                  loop
                  preload="metadata"
                  poster={project.media.poster}
                  disablepictureinpicture
                  playsinline
                  class="max-h-full max-w-full m-auto rounded-sm shadow-xl"
                  data-play-on-view
                />
              </div>
            </div>
          </article>
        </li>
      ))
    }
  </ul>
</section>
