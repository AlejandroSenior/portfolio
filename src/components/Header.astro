---
import Icon from '@components/Icon.astro';
import { navLinks } from '@data/site';
import { languages, type Lang } from '@i18n/ui';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '@i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const otherLang = (Object.keys(languages) as Lang[]).find((code) => code !== lang) ?? lang;
const switchLangHref = translatePath('/', otherLang) + Astro.url.hash;
---

<header id="site-header" class="fixed top-0 z-50 w-full content-center duration-300 animate-fade-down opacity-0 animate-delay-200">
  <div class="mx-auto flex max-w-screen-xl items-center justify-between px-6 py-4 font-header md:justify-around">
    <!-- Desktop navigation -->
    <nav class="hidden w-full justify-between md:flex">
      <ul class="flex items-center font-medium text-base gap-8">
        {
          navLinks.map((link) => (
            <li>
              <a
                onclick={`window.smoothScrollTo('${link.href}', event)`}
                href={link.href}
                aria-label={`${t('a11y.linkTo')} "${t(link.label).toLowerCase()}"`}
                class="group font-medium text-base inline-flex items-center justify-center gap-x-2"
              >
                <Icon name={link.icon} />
                <span>{t(link.label)}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Mobile hamburger + lang switch -->
    <div class="flex items-center w-full justify-between md:hidden">
      <button
        type="button"
        data-hamburger
        aria-haspopup="dialog"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="inline-flex items-center justify-center whitespace-nowrap rounded-md text-base font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 hover:bg-accent hover:text-accent-foreground h-10 aspect-square p-0.5"
      >
        <span class="sr-only">{t('nav.menu')}</span>
        <svg class="pointer-events-none h-6 w-6 fill-current" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg">
          <rect y="2" x="7" width="9" height="2" rx="1"></rect>
          <rect y="7" width="16" height="2" rx="1"></rect>
          <rect y="12" width="9" height="2" rx="1"></rect>
        </svg>
      </button>

      <a
        href={switchLangHref}
        hreflang={otherLang}
        lang={otherLang}
        aria-label={`${t('nav.language')}: ${languages[otherLang]}`}
        class="inline-flex items-center justify-center gap-x-1.5 h-10 px-2 rounded-md text-base font-semibold tracking-wide ring-offset-background transition-colors hover:bg-accent hover:text-accent-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 text-foreground/80"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m5 8 6 6"></path>
          <path d="m4 14 6-6 2-3"></path>
          <path d="M2 5h12"></path>
          <path d="M7 2h1"></path>
          <path d="m22 22-5-10-5 10"></path>
          <path d="M14 18h6"></path>
        </svg>
        <span>{otherLang.toUpperCase()}</span>
      </a>
    </div>

    <!-- Language selector -->
    <a
      href={switchLangHref}
      hreflang={otherLang}
      lang={otherLang}
      aria-label={`${t('nav.language')}: ${languages[otherLang]}`}
      class="hidden md:flex h-10 items-center justify-end gap-x-2 px-3 py-2 text-base ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 w-fit text-foreground/80"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="mr-0.5 size-[1.2em] md:mb-1"
      >
        <path d="m5 8 6 6"></path>
        <path d="m4 14 6-6 2-3"></path>
        <path d="M2 5h12"></path>
        <path d="M7 2h1"></path>
        <path d="m22 22-5-10-5 10"></path>
        <path d="M14 18h6"></path>
      </svg>
      <span class="font-semibold tracking-wide">{otherLang.toUpperCase()}</span>
    </a>
  </div>
</header>

<!-- Mobile menu panel -->
<div
  id="mobile-menu"
  data-mobile-menu
  hidden
  class="fixed inset-x-4 bottom-4 z-50 hidden rounded-2xl border border-border backdrop-blur-md md:hidden"
>
  <div class="max-h-[80vh] overflow-y-scroll">
    <nav class="grid w-full grid-cols-1 [&>ul]:my-6 [&>ul]:justify-self-center">
      <ul class="flex items-center font-medium text-base w-max flex-col gap-6 mx-auto">
        {
          navLinks.map((link) => (
            <li>
              <a
                onclick={`window.smoothScrollTo('${link.href}', event)`}
                href={link.href}
                aria-label={`${t('a11y.linkTo')} "${t(link.label).toLowerCase()}"`}
                class="group font-medium inline-flex items-center justify-center gap-x-4 text-2xl"
              >
                <Icon name={link.icon} />
                <span>{t(link.label)}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</div>

<!-- Mobile menu backdrop -->
<div data-menu-backdrop hidden class="fixed inset-0 z-40 bg-black/60 md:hidden"></div>

<script>
  const header = document.getElementById('site-header');
  const onScroll = () => {
    if (window.scrollY > 10) {
      header?.classList.add('bg-background');
    } else {
      header?.classList.remove('bg-background');
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
</script>
