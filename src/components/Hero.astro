---
const socials = [
  {
    name: 'GitHub',
    href: 'https://github.com',
    label: 'GitHub',
    icon: `<svg class="w-[18px] h-[18px]" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>`,
  },
  {
    name: 'LinkedIn',
    href: 'https://linkedin.com',
    label: 'LinkedIn',
    icon: `<svg class="w-[18px] h-[18px]" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
  {
    name: 'Twitter / X',
    href: 'https://twitter.com',
    label: 'Twitter / X',
    icon: `<svg class="w-[18px] h-[18px]" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  },
  {
    name: 'Email',
    href: 'mailto:alejandroanimasoluciones@gmail.com',
    label: 'Correo',
    icon: `<svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>`,
  },
];
---

<section class="relative min-h-screen flex items-center overflow-hidden pt-16">

  <!-- Dot grid -->
  <div class="hero-dot-grid pointer-events-none absolute inset-0" aria-hidden="true"></div>

  <!-- Aurora blobs -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
    <!-- Primary indigo blob — top center -->
    <div
      class="absolute rounded-full"
      style="
        width: 680px; height: 680px;
        top: -240px; left: 50%; margin-left: -340px;
        background: radial-gradient(circle, #818cf8 0%, transparent 65%);
        filter: blur(90px);
        opacity: 0.09;
        animation: blobFloat 14s ease-in-out infinite;
      "
    ></div>
    <!-- Pink blob — bottom right -->
    <div
      class="absolute rounded-full"
      style="
        width: 480px; height: 480px;
        bottom: -160px; right: -80px;
        background: radial-gradient(circle, #f472b6 0%, transparent 65%);
        filter: blur(80px);
        opacity: 0.08;
        animation: blobFloatAlt 18s ease-in-out infinite;
      "
    ></div>
    <!-- Accent sky blob — left middle -->
    <div
      class="absolute rounded-full"
      style="
        width: 340px; height: 340px;
        top: 40%; left: -80px;
        background: radial-gradient(circle, #38bdf8 0%, transparent 65%);
        filter: blur(70px);
        opacity: 0.05;
        animation: blobFloat 22s ease-in-out infinite 6s;
      "
    ></div>
    <!-- Small indigo accent — top right -->
    <div
      class="absolute rounded-full"
      style="
        width: 200px; height: 200px;
        top: 15%; right: 10%;
        background: radial-gradient(circle, #6366f1 0%, transparent 65%);
        filter: blur(50px);
        opacity: 0.07;
        animation: blobPulse 8s ease-in-out infinite;
      "
    ></div>
  </div>

  <!-- Floating geometric shapes (right side, away from text) -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden hidden md:block" aria-hidden="true">
    <!-- Square outline -->
    <div
      style="
        position: absolute; top: 22%; right: 14%;
        width: 38px; height: 38px;
        border: 1px solid rgba(129,140,248,0.18);
        border-radius: 8px;
        transform: rotate(18deg);
        animation: geoFloat 14s ease-in-out infinite;
        opacity: 0.5;
      "
    ></div>
    <!-- Circle outline -->
    <div
      style="
        position: absolute; top: 55%; right: 22%;
        width: 22px; height: 22px;
        border: 1px solid rgba(244,114,182,0.2);
        border-radius: 9999px;
        animation: geoFloatAlt 19s ease-in-out infinite 3s;
        opacity: 0.45;
      "
    ></div>
    <!-- Large circle ring -->
    <div
      style="
        position: absolute; top: 35%; right: 6%;
        width: 70px; height: 70px;
        border: 1px solid rgba(129,140,248,0.1);
        border-radius: 9999px;
        animation: geoFloat 26s ease-in-out infinite 8s;
        opacity: 0.35;
      "
    ></div>
    <!-- Tiny square -->
    <div
      style="
        position: absolute; top: 68%; right: 9%;
        width: 14px; height: 14px;
        border: 1px solid rgba(56,189,248,0.2);
        border-radius: 3px;
        transform: rotate(30deg);
        animation: geoFloatAlt 16s ease-in-out infinite 2s;
        opacity: 0.4;
      "
    ></div>
  </div>

  <!-- ── Main content ── -->
  <div class="relative max-w-5xl mx-auto px-6 py-28 w-full">

    <!-- Available badge -->
    <div class="hero-badge-anim mb-8">
      <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full border border-white/10 bg-white/[0.04] text-xs text-gray-custom">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75 animate-ping"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-green-400"></span>
        </span>
        Disponible para nuevos proyectos
      </div>
    </div>

    <!-- Greeting -->
    <div class="hero-item" style="--delay: 0.18s">
      <p class="text-gray-custom text-xl mb-2 font-medium">
        ¡Hola! <span class="wave-emoji">👋</span> Soy
      </p>
    </div>

    <!-- Name -->
    <div class="hero-item" style="--delay: 0.28s">
      <h1 class="text-6xl md:text-7xl font-bold tracking-tight leading-[1.05] mb-5">
        <span class="gradient-text">Tu Nombre</span>
      </h1>
    </div>

    <!-- Typewriter role -->
    <div class="hero-item mb-6" style="--delay: 0.4s">
      <p class="text-lg text-primary font-medium tracking-wide h-7 flex items-center">
        <span id="hero-typewriter"></span><span class="typewriter-cursor"></span>
      </p>
    </div>

    <!-- Tagline -->
    <div class="hero-item" style="--delay: 0.52s">
      <p class="text-xl text-gray-custom leading-relaxed max-w-lg mb-9">
        Desarrollador de
        <span class="text-white font-medium">software</span> apasionado por construir
        productos digitales <span class="text-white font-medium">elegantes y funcionales</span>
        que resuelven problemas reales.
      </p>
    </div>

    <!-- CTA buttons -->
    <div class="hero-item flex items-center gap-3 flex-wrap mb-9" style="--delay: 0.62s">
      <a href="#proyectos" class="hero-btn-primary">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z"/>
        </svg>
        Ver proyectos
      </a>
      <a href="#contacto" class="hero-btn-secondary">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z"/>
        </svg>
        Contáctame
      </a>
    </div>

    <!-- Social links -->
    <div class="hero-item" style="--delay: 0.72s">
      <div class="flex items-center gap-2 flex-wrap">
        {socials.map((s) => (
          <a
            href={s.href}
            target={s.href.startsWith('mailto') ? undefined : '_blank'}
            rel={s.href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
            aria-label={s.label}
            class="group flex items-center gap-2 px-3.5 py-2 rounded-lg border border-white/[0.07] bg-white/[0.03] text-gray-custom hover:text-white hover:border-primary/40 hover:bg-primary/[0.06] transition-all duration-200 text-xs font-medium"
          >
            <span set:html={s.icon} />
            <span>{s.name}</span>
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-indicator absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1.5" aria-hidden="true">
    <span class="text-[10px] text-gray-custom/40 tracking-widest uppercase">scroll</span>
    <div class="mouse-body">
      <div class="mouse-wheel"></div>
    </div>
  </div>
</section>

<script>
  const roles = [
    'Full Stack Developer',
    'Backend Engineer',
    'UI/UX Enthusiast',
    'Problem Solver',
  ];

  const el = document.getElementById('hero-typewriter');
  if (el) {
    const target = el;
    let roleIdx = 0;
    let charIdx = 0;
    let deleting = false;

    function tick() {
      const current = roles[roleIdx];
      if (deleting) {
        charIdx--;
        target.textContent = current.slice(0, charIdx);
      } else {
        charIdx++;
        target.textContent = current.slice(0, charIdx);
      }

      let delay = deleting ? 45 : 90;

      if (!deleting && charIdx === current.length) {
        delay = 2200;
        deleting = true;
      } else if (deleting && charIdx === 0) {
        deleting = false;
        roleIdx = (roleIdx + 1) % roles.length;
        delay = 380;
      }

      setTimeout(tick, delay);
    }

    setTimeout(tick, 1100);
  }
</script>
