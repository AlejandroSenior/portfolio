---
const experiences = [
  {
    title: 'Desarrollador de Software',
    company: 'Empresa Actual',
    companyUrl: 'https://example.com',
    location: 'Ciudad, País',
    period: 'Nov 2024 – Presente',
    description:
      'Descripción de tu rol actual y responsabilidades principales. Menciona tecnologías, impacto y logros destacados en tu día a día.',
    tags: ['TypeScript', 'React', 'Node.js', 'AWS'],
  },
  {
    title: 'Desarrollador Full Stack',
    company: 'Empresa Anterior',
    companyUrl: 'https://example.com',
    location: 'Ciudad, País',
    period: 'Ene 2022 – Oct 2024',
    description:
      'Descripción de tu rol anterior. Incluye proyectos importantes, el impacto que generaste y las tecnologías que manejaste a diario.',
    tags: ['JavaScript', 'Vue.js', 'Python', 'Docker'],
  },
  {
    title: 'Desarrollador Junior',
    company: 'Primera Empresa',
    companyUrl: 'https://example.com',
    location: 'Ciudad, País',
    period: 'Mar 2020 – Dic 2021',
    description:
      'Descripción de tu primer rol profesional. Destaca el aprendizaje, los proyectos en los que participaste y tu crecimiento técnico.',
    tags: ['HTML', 'CSS', 'JavaScript', 'Git'],
  },
];
---

<section id="experiencia" class="py-28">
  <div class="max-w-5xl mx-auto px-6">
    <!-- Section label -->
    <div class="animate-on-scroll">
      <p class="section-label">01 — Experiencia</p>
      <h2 class="text-4xl font-bold tracking-tight mb-14">
        Dónde he <span class="gradient-text">trabajado</span>
      </h2>
    </div>

    <div class="relative">
      <!-- Vertical line -->
      <div class="absolute left-0 top-2 bottom-2 w-px bg-white/6 hidden sm:block" aria-hidden="true"></div>

      <div class="space-y-5 sm:pl-8">
        {experiences.map((exp) => (
          <article class="animate-on-scroll group relative">
            <!-- Timeline dot -->
            <div
              class="absolute -left-9.25 top-5 hidden sm:flex items-center justify-center w-3 h-3 rounded-full border border-white/20 bg-dark group-hover:border-primary/60 group-hover:bg-primary/10 transition-all duration-300"
              aria-hidden="true"
            ></div>

            <div class="rounded-2xl border border-white/6 bg-dark-lighter p-6 card-hover">
              <!-- Header row -->
              <div class="flex flex-wrap items-start justify-between gap-x-4 gap-y-1 mb-1">
                <h3 class="text-lg font-semibold leading-snug">
                  {exp.title}
                  <span class="text-gray-custom font-normal"> · </span>
                  <a
                    href={exp.companyUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-primary hover:text-primary-dark underline underline-offset-2 decoration-primary/30 hover:decoration-primary transition-colors"
                  >
                    {exp.company}
                  </a>
                </h3>
                <span class="text-sm text-gray-custom shrink-0 mt-0.5 tabular-nums">{exp.period}</span>
              </div>

              <p class="text-sm text-gray-custom mb-4">{exp.location}</p>
              <p class="text-base text-white/70 leading-relaxed mb-5">{exp.description}</p>

              <div class="flex flex-wrap gap-1.5">
                {exp.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
